  screenId: ScreenId,
  data:     Record<string, unknown>
): ScreenStateName | null {
  const shieldLevel   = useShieldStore(s => s.currentLevel);
  const isBereavement = useBereavementStore(s => s.isActive);

  return useMemo((): ScreenStateName | null => {
    // Highest priority: alert states
    if (shieldLevel === 'red')   return 'RED_ALERT';
    if (shieldLevel === 'amber') return 'AMBER_ALERT';

    // Bereavement
    if (isBereavement) return 'BEREAVEMENT';

    // Data-derived states
    const medOverdue = data.currentReminder &&
      (data.currentReminder as { isOverdue?: boolean }).isOverdue;
    if (medOverdue) return 'MEDICATION_OVERDUE';

    // Offline check
    if (data._offline) return 'OFFLINE';

    return null;
  }, [shieldLevel, isBereavement, data]);
}

// ─────────────────────────────────────────────────────────────────────────────
// hooks/useVoiceEngine.ts
// Manages voice I/O for a screen — STT input + TTS output
// ─────────────────────────────────────────────────────────────────────────────

import { useEffect, useCallback, useRef, useState } from 'react';
import * as Speech from 'expo-speech';
import { ExpoSpeechRecognitionModule, useSpeechRecognitionEvent } from 'expo-speech-recognition';
import type { VoiceSchema, VoiceIntent } from '../schema/types';
import { useTemplateString } from './useTemplateString';
import { useIntentClassifier } from './useIntentClassifier';

interface UseVoiceEngineProps {
  voiceSchema:  VoiceSchema;
  data:         Record<string, unknown>;
  screenId:     string;
  onIntent:     (intent: VoiceIntent, slots?: Record<string, string>) => void;
}

export function useVoiceEngine({
  voiceSchema, data, screenId, onIntent
}: UseVoiceEngineProps) {
  const [isListening,  setIsListening]  = useState(false);
  const [isSpeaking,   setIsSpeaking]   = useState(false);
  const { fill }         = useTemplateString(data);
  const { classify }     = useIntentClassifier(voiceSchema.commands);
  const hasSpokenEntry   = useRef(false);

  // ── Entry speak (once per screen mount) ───────────────────────────────────
  useEffect(() => {
    if (!voiceSchema.entrySpeak || hasSpokenEntry.current) return;
    if (voiceSchema.entrySpeak.skipIfSilentMode && isSilentMode()) return;

    const text    = fill(voiceSchema.entrySpeak.template);
    const delay   = voiceSchema.entrySpeak.delay_ms ?? 0;
    const timeout = setTimeout(() => {
      setIsSpeaking(true);
      Speech.speak(text, {
        language: 'en',
        pitch:    1.0,
        rate:     0.9,
        onDone:   () => {
          setIsSpeaking(false);
          // After entry speak, auto-listen if always-listening mode
          if (voiceSchema.alwaysListening) startListening();
        },
      });
      hasSpokenEntry.current = true;
    }, delay);

    return () => clearTimeout(timeout);
  }, [screenId]);  // only on screen mount

  // ── STT ───────────────────────────────────────────────────────────────────
  const startListening = useCallback(async () => {
    setIsListening(true);
    await ExpoSpeechRecognitionModule.start({
      lang:                'en-US',
      interimResults:      false,
      maxAlternatives:     3,
      contextualStrings:   getContextualHints(voiceSchema.commands),
    });
  }, [voiceSchema.commands]);

  useSpeechRecognitionEvent('result', (event) => {
    if (!event.results?.[0]) {
      handleFallback();
      return;
    }

    const transcript    = event.results[0].transcript.toLowerCase().trim();
    const classification= classify(transcript);

    if (classification) {
      const { intent, slots } = classification;
      if (voiceSchema.commands.find(c => c.intent === intent)?.confirmBefore) {
        // Show confirmation before acting
        speakConfirmation(
          voiceSchema.commands.find(c => c.intent === intent)!.confirmMessage ?? "Are you sure?",
          () => onIntent(intent, slots)
        );
      } else {
        onIntent(intent, slots);
      }
    } else {
      handleFallback();
    }

    setIsListening(false);
  });

  useSpeechRecognitionEvent('end', () => setIsListening(false));
  useSpeechRecognitionEvent('error', () => {
    setIsListening(false);
    handleFallback();
  });

  const handleFallback = useCallback(() => {
    const { fallback } = voiceSchema;
    Speech.speak(fallback.message, { rate: 0.9 });
  }, [voiceSchema.fallback]);

  const speakConfirmation = useCallback((message: string, onConfirm: () => void) => {
    Speech.speak(message, {
      rate:   0.9,
      onDone: () => {
        // After speaking confirmation, listen for yes/no
        startListening();
        // Simple yes/no handler — re-registered once
      },
    });
  }, []);

  return { isListening, isSpeaking, startListening };
}

// Derive contextual hints from command utterances to improve STT accuracy
function getContextualHints(commands: VoiceSchema['commands']): string[] {
  return commands
    .flatMap(c => c.utterances)
    .filter(u => !u.includes('*'))  // exclude wildcards
    .slice(0, 100);                  // STT APIs limit contextual hints
}

function isSilentMode(): boolean {
  // Platform-specific silent mode check
  return false; // Implement via expo-av AudioMode
}

// ─────────────────────────────────────────────────────────────────────────────
// hooks/useSchemaValidator.ts
// Build-time + runtime schema validation
// ─────────────────────────────────────────────────────────────────────────────

import type { ScreenSchema } from '../schema/types';

export function useSchemaValidator() {
  const validate = (schema: ScreenSchema) => {
    const errors: string[] = [];

    // Rule 1: Max 3 primary items
    const primaryItems = schema.contentBlocks.filter(b =>
      ['CARD', 'MED_NEXT', 'BUTTON_GRID', 'LIST'].includes(b.blockType)
    );
    if (primaryItems.length > schema.maxPrimaryItems) {
      errors.push(`[${schema.screenId}] Too many primary blocks: ${primaryItems.length} > ${schema.maxPrimaryItems}`);
    }

    // Rule 2: Max 2 bottom actions
    if (schema.bottomActions.length > 2) {
      errors.push(`[${schema.screenId}] Too many bottom actions: ${schema.bottomActions.length} > 2`);
    }

    // Rule 3: Navigation depth ≤ 2
    if (schema.navigation.depthFromHome > 2) {
      errors.push(`[${schema.screenId}] Navigation depth ${schema.navigation.depthFromHome} exceeds maximum of 2`);
    }

    // Rule 4: All HeroButtons have accessibilityLabel
    const gridBlocks = schema.contentBlocks.filter(b => b.blockType === 'BUTTON_GRID');
    gridBlocks.forEach((grid: unknown) => {
      (grid as { buttons: { accessibilityLabel?: string }[] }).buttons?.forEach((btn, idx) => {
        if (!btn.accessibilityLabel) {
          errors.push(`[${schema.screenId}] Button grid button[${idx}] missing accessibilityLabel`);
        }
      });
    });

    // Rule 5: Voice fallback always defined
    if (!schema.voice.fallback) {
      errors.push(`[${schema.screenId}] Missing voice fallback`);
    }

    if (errors.length > 0) {
      console.error('[HAVEN Schema Validator]\n' + errors.join('\n'));
      if (process.env.NODE_ENV === 'test') {
        throw new Error('[HAVEN Schema Validator] Schema violations found:\n' + errors.join('\n'));
      }
    }

    return errors;
  };

  return { validate };
}

// ─────────────────────────────────────────────────────────────────────────────
// hooks/useVisibility.ts
// Evaluates VisibilityCondition against live data
// ─────────────────────────────────────────────────────────────────────────────

import type { VisibilityCondition } from '../schema/types';
import { useShieldStore }     from '../stores/shieldStore';
import { useBereavementStore } from '../stores/bereavementStore';
import { useFeatureFlags }    from './useFeatureFlags';
import { useElderSettings }   from './useElderSettings';

export function useVisibility(data: Record<string, unknown>) {
  const shieldLevel   = useShieldStore(s => s.currentLevel);
  const isBereavement = useBereavementStore(s => s.isActive);
  const { getFlag }   = useFeatureFlags();
  const { getSetting } = useElderSettings();

  const isVisible = (condition: VisibilityCondition): boolean => {
    switch (condition.condition) {

      case 'DATA_EXISTS':
        return data[condition.dataKey] != null &&
               (Array.isArray(data[condition.dataKey])
                 ? (data[condition.dataKey] as unknown[]).length > 0
                 : true);

      case 'DATA_EMPTY':
        return data[condition.dataKey] == null ||
               (Array.isArray(data[condition.dataKey])
                 ? (data[condition.dataKey] as unknown[]).length === 0
                 : false);

      case 'FEATURE_FLAG':
        return getFlag(condition.flag);

      case 'USER_SETTING':
        return getSetting(condition.setting) === condition.value;

      case 'ALERT_LEVEL':
        return shieldLevel === condition.level;

      case 'TIME_OF_DAY': {
        const now   = new Date();
        const hours = now.getHours() * 60 + now.getMinutes();
        const from  = timeToMinutes(condition.from);
        const to    = timeToMinutes(condition.to);
        return from <= to ? hours >= from && hours <= to
                          : hours >= from || hours <= to;  // overnight range
      }

      case 'BEREAVEMENT_ACTIVE':
        return isBereavement;

      case 'AND':
        return condition.conditions.every(isVisible);

      case 'OR':
        return condition.conditions.some(isVisible);

      default:
        return true;
    }
  };

  return { isVisible };
}

function timeToMinutes(time: string): number {
  const [h, m] = time.split(':').map(Number);
  return h * 60 + (m ?? 0);
}

