Part 3 — React Native Renderer Architecture
This is the engine that turns a ScreenSchema into a real, bespoke, pixel-perfect screen. The key insight: the renderer is the complexity; the schema is the clarity.

TypeScript

// renderer/ScreenRenderer.tsx
// ─────────────────────────────────────────────────────────────────────────────
// HAVEN SCREEN RENDERER
// Turns any ScreenSchema into a fully accessible, elder-safe screen.
// ─────────────────────────────────────────────────────────────────────────────

import React, { useEffect, useMemo, useCallback } from 'react';
import {
  View, ScrollView, StyleSheet, AccessibilityInfo, Platform,
} from 'react-native';
import Animated, {
  useSharedValue, useAnimatedStyle,
  withSpring, withTiming, withRepeat, withSequence,
  FadeIn, SlideInDown, ZoomIn,
} from 'react-native-reanimated';
import { useSafeAreaInsets } from 'react-native-safe-area-context';
import * as Haptics from 'expo-haptics';

import type { ScreenSchema, ContentBlock, ScreenStateOverride } from '../schema/types';
import { useScreenData }        from '../hooks/useScreenData';
import { useScreenState }       from '../hooks/useScreenState';
import { useVoiceEngine }       from '../hooks/useVoiceEngine';
import { useHavenTheme }        from '../hooks/useHavenTheme';
import { useVisibility }        from '../hooks/useVisibility';
import { useActionHandler }     from '../hooks/useActionHandler';
import { useSchemaValidator }   from '../hooks/useSchemaValidator';
import { useAnalytics }         from '../hooks/useAnalytics';
import { useTemplateString }    from '../hooks/useTemplateString';

// Block renderers
import { renderGreetingBlock }      from './blocks/GreetingBlock';
import { renderHaloBlock }          from './blocks/HaloBlock';
import { renderButtonGridBlock }    from './blocks/ButtonGridBlock';
import { renderCardBlock }          from './blocks/CardBlock';
import { renderListBlock }          from './blocks/ListBlock';
import { renderMedNextBlock }       from './blocks/MedNextBlock';
import { renderVoicePromptBlock }   from './blocks/VoicePromptBlock';
import { renderRecorderBlock }      from './blocks/RecorderBlock';
import { renderAlertBlock }         from './blocks/AlertExplanationBlock';
import { renderCoachingCardBlock }  from './blocks/CoachingCardBlock';
import { renderDocSummaryBlock }    from './blocks/DocumentSummaryBlock';
import { renderWellnessBlock }      from './blocks/WellnessSelectorBlock';
import { renderCognitiveBlock }     from './blocks/CognitiveChallengeBlock';
import { renderPhotoGridBlock }     from './blocks/PhotoGridBlock';
import { renderFamilyListBlock }    from './blocks/FamilyListBlock';
import { renderTextBlock }          from './blocks/TextBlock';
import { renderDividerBlock }       from './blocks/DividerBlock';
import { renderSpacerBlock }        from './blocks/SpacerBlock';

// Persistent components
import { HEmergencyButton }     from '../components/HEmergencyButton';
import { HVoiceButton }         from '../components/HVoiceButton';
import { HStatusHalo }          from '../components/HStatusHalo';
import { HBackButton }          from '../components/HBackButton';
import { HScreenHeader }        from '../components/HScreenHeader';
import { HBottomActions }       from '../components/HBottomActions';
import { HLoadingState }        from '../components/HLoadingState';
import { HEmptyState }          from '../components/HEmptyState';

// ─────────────────────────────────────────────────────────────────────────────

interface ScreenRendererProps {
  schema:         ScreenSchema;
  routeParams?:   Record<string, string>;
  testID?:        string;
}

export const ScreenRenderer: React.FC<ScreenRendererProps> = ({
  schema,
  routeParams,
  testID,
}) => {
  const insets      = useSafeAreaInsets();
  const theme       = useHavenTheme();
  const analytics   = useAnalytics();
  const { handle }  = useActionHandler(schema.screenId);

  // ── 0. Schema validation (dev only) ─────────────────────────────────────
  const { validate } = useSchemaValidator();
  useEffect(() => {
    if (__DEV__) validate(schema);
  }, [schema]);

  // ── 1. Load all declared data sources ───────────────────────────────────
  const { data, isLoading, isError, isOffline } = useScreenData(
    schema.dataSources,
    { routeParams }
  );

  // ── 2. Determine current screen state ───────────────────────────────────
  const currentState = useScreenState(schema.screenId, data);

  // ── 3. Merge state overrides ─────────────────────────────────────────────
  const mergedSchema: ScreenSchema = useMemo(() => {
    if (!currentState || !schema.states?.[currentState]) return schema;
    const override = schema.states[currentState] as ScreenStateOverride;
    return {
      ...schema,
      backgroundColor: override.backgroundColor  ?? schema.backgroundColor,
      headerVariant:   override.headerVariant    ?? schema.headerVariant,
      contentBlocks:   override.replaceBlocks    ?? [
        ...schema.contentBlocks,
        ...(override.extraBlocks ?? []),
      ],
      bottomActions:   override.bottomActions    ?? schema.bottomActions,
      voice: override.voiceOverride
        ? { ...schema.voice, ...override.voiceOverride }
        : schema.voice,
    };
  }, [schema, currentState]);

  // ── 4. Boot voice engine for this screen ─────────────────────────────────
  const { isListening, isSpeaking, startListening } = useVoiceEngine({
    voiceSchema:  mergedSchema.voice,
    data,
    screenId:     mergedSchema.screenId,
    onIntent:     handle,
  });

  // ── 5. Track screen view ──────────────────────────────────────────────────
  useEffect(() => {
    analytics.screen(mergedSchema.trackingId, { state: currentState });
    AccessibilityInfo.announceForAccessibility(mergedSchema.accessibilityLabel);
  }, [mergedSchema.screenId]);

  // ── 6. Background color ───────────────────────────────────────────────────
  const bgColor = theme.resolveColor(
    mergedSchema.backgroundColor ?? 'bg.primary',
    currentState
  );

  // ── 7. Layout variant ─────────────────────────────────────────────────────
  const isOverlay  = mergedSchema.navigation.isOverlay;
  const isModal    = mergedSchema.navigation.isModal;

  // ── 8. Loading state ──────────────────────────────────────────────────────
  if (isLoading) {
    return (
      <HLoadingState
        message="Getting things ready…"
        backgroundColor={bgColor}
        testID={`${testID}-loading`}
      />
    );
  }

  // ── 9. Render ─────────────────────────────────────────────────────────────
  return (
    <View
      style={[
        styles.root,
        { backgroundColor: bgColor, paddingTop: insets.top },
        isOverlay && styles.overlay,
        isModal   && styles.modal,
      ]}
      testID={testID}
      accessibilityLabel={mergedSchema.accessibilityLabel}
    >
      {/* HEADER */}
      <HScreenHeader
        variant={mergedSchema.headerVariant ?? 'TITLE_BACK'}
        title={mergedSchema.title}
        screenId={mergedSchema.screenId}
        data={data}
      />

      {/* CONTENT */}
      <ScrollView
        style={styles.scrollView}
        contentContainerStyle={[
          styles.scrollContent,
          { paddingBottom: insets.bottom + 120 }, // clear bottom actions
        ]}
        showsVerticalScrollIndicator={false}
        accessibilityRole="main"
        bounces={false}
      >
        <BlockRenderer
          blocks={mergedSchema.contentBlocks}
          data={data}
          layout={mergedSchema.layout}
          onAction={handle}
          isOffline={isOffline}
          currentState={currentState}
        />
      </ScrollView>

      {/* BOTTOM ACTIONS (fixed) */}
      {mergedSchema.bottomActions.length > 0 && (
        <HBottomActions
          actions={mergedSchema.bottomActions}
          data={data}
          onAction={handle}
          insets={insets}
        />
      )}

      {/* PERSISTENT ELEMENTS */}
      <PersistentElements
        elements={mergedSchema.persistent}
        data={data}
        isListening={isListening}
        onVoiceTap={startListening}
        onAction={handle}
        insets={insets}
      />
    </View>
  );
};

// ─────────────────────────────────────────────────────────────────────────────
// BLOCK RENDERER
// Dispatches to the correct block renderer based on blockType
// ─────────────────────────────────────────────────────────────────────────────

interface BlockRendererProps {
  blocks:       ContentBlock[];
  data:         Record<string, unknown>;
  layout:       string;
  onAction:     (action: unknown) => void;
  isOffline:    boolean;
  currentState: string | null;
}

export const BlockRenderer: React.FC<BlockRendererProps> = ({
  blocks, data, layout, onAction, isOffline, currentState
}) => {
  const { isVisible } = useVisibility(data);

  return (
    <>
      {blocks
        .filter(block => !block.visible || isVisible(block.visible))
        .map(block => (
          <AnimatedBlock
            key={block.blockId}
            block={block}
            data={data}
            layout={layout}
            onAction={onAction}
          />
        ))
      }
    </>
  );
};

// ─────────────────────────────────────────────────────────────────────────────
// ANIMATED BLOCK WRAPPER
// Applies entry animation then renders the block
// ─────────────────────────────────────────────────────────────────────────────

interface AnimatedBlockProps {
  block:    ContentBlock;
  data:     Record<string, unknown>;
  layout:   string;
  onAction: (action: unknown) => void;
}

const AnimatedBlock: React.FC<AnimatedBlockProps> = ({
  block, data, layout, onAction
}) => {
  const animSpec  = block.animateIn;

  const entering = useMemo(() => {
    if (!animSpec) return undefined;
    switch (animSpec.type) {
      case 'SLIDE_UP':   return SlideInDown.duration(animSpec.duration).delay(animSpec.delay ?? 0);
      case 'FADE_IN':    return FadeIn.duration(animSpec.duration).delay(animSpec.delay ?? 0);
      case 'SCALE_IN':   return ZoomIn.duration(animSpec.duration).delay(animSpec.delay ?? 0);
      default:           return undefined;
    }
  }, [animSpec]);

  return (
    <Animated.View entering={entering}>
      <BlockSwitch block={block} data={data} layout={layout} onAction={onAction} />
    </Animated.View>
  );
};

// ─────────────────────────────────────────────────────────────────────────────
// BLOCK SWITCH
// Type-narrows the ContentBlock union and calls the right renderer
// ─────────────────────────────────────────────────────────────────────────────

const BlockSwitch: React.FC<AnimatedBlockProps> = ({ block, data, layout, onAction }) => {
  switch (block.blockType) {
    case 'GREETING':          return renderGreetingBlock(block, data);
    case 'HALO':              return renderHaloBlock(block, data);
    case 'BUTTON_GRID':       return renderButtonGridBlock(block, data, onAction);
    case 'CARD':              return renderCardBlock(block, data, onAction);
    case 'LIST':              return renderListBlock(block, data, onAction);
    case 'MED_NEXT':          return renderMedNextBlock(block, data, onAction);
    case 'VOICE_PROMPT':      return renderVoicePromptBlock(block, data, onAction);
    case 'RECORDER':          return renderRecorderBlock(block, data, onAction);
    case 'ALERT_EXPLANATION': return renderAlertBlock(block, data);
    case 'COACHING_CARD':     return renderCoachingCardBlock(block, data);
    case 'DOCUMENT_SUMMARY':  return renderDocSummaryBlock(block, data, onAction);
    case 'WELLNESS_SELECTOR': return renderWellnessBlock(block, data, onAction);
    case 'COGNITIVE_CHALLENGE': return renderCognitiveBlock(block, data, onAction);
    case 'PHOTO_GRID':        return renderPhotoGridBlock(block, data, onAction);
    case 'FAMILY_LIST':       return renderFamilyListBlock(block, data, onAction);
    case 'TEXT':              return renderTextBlock(block, data);
    case 'DIVIDER':           return renderDividerBlock(block);
    case 'SPACER':            return renderSpacerBlock(block);
    default: {
      if (__DEV__) console.warn(`[HAVEN] Unknown block type: ${(block as ContentBlock).blockType}`);
      return null;
    }
  }
};

// ─────────────────────────────────────────────────────────────────────────────
// PERSISTENT ELEMENTS
// ─────────────────────────────────────────────────────────────────────────────

interface PersistentElementsProps {
  elements:       string[];
  data:           Record<string, unknown>;
  isListening:    boolean;
  onVoiceTap:     () => void;
  onAction:       (action: unknown) => void;
  insets:         { bottom: number; right: number };
}

const PersistentElements: React.FC<PersistentElementsProps> = ({
  elements, data, isListening, onVoiceTap, onAction, insets
}) => (
  <>
    {elements.includes('EMERGENCY_BUTTON') && (
