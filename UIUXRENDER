// SCHEMA COMPLIANCE TEST SUITE
// Runs in CI. Any schema violation fails the build.
// This is how simplicity is ENFORCED, not just recommended.
// ─────────────────────────────────────────────────────────────────────────────

import { SCREEN_REGISTRY } from '../schema/screens';
import type { ScreenSchema, ContentBlock } from '../schema/types';

const schemas = Object.values(SCREEN_REGISTRY);

describe('HAVEN Schema Compliance', () => {

  describe('Navigation Depth', () => {
    test.each(schemas)('[$screenId] depth from home ≤ 2', (schema) => {
      expect(schema.navigation.depthFromHome).toBeLessThanOrEqual(2);
    });
  });

  describe('Bottom Actions', () => {
    test.each(schemas)('[$screenId] max 2 bottom actions', (schema) => {
      expect(schema.bottomActions.length).toBeLessThanOrEqual(2);
    });
  });

  describe('Content Blocks', () => {
    test.each(schemas)('[$screenId] maxPrimaryItems respected', (schema) => {
      const primaryBlocks = schema.contentBlocks.filter(b =>
        ['CARD', 'MED_NEXT', 'BUTTON_GRID', 'LIST'].includes(b.blockType)
      );
      expect(primaryBlocks.length).toBeLessThanOrEqual(schema.maxPrimaryItems);
    });

    test.each(schemas)('[$screenId] all blocks have blockId', (schema) => {
      schema.contentBlocks.forEach(block => {
        expect(block.blockId).toBeTruthy();
        expect(typeof block.blockId).toBe('string');
      });
    });
  });

  describe('Accessibility', () => {
    test.each(schemas)('[$screenId] has accessibilityLabel', (schema) => {
      expect(schema.accessibilityLabel).toBeTruthy();
    });

    test.each(schemas)('[$screenId] all bottom actions have accessibilityLabel', (schema) => {
      schema.bottomActions.forEach(action => {
        expect(action.accessibilityLabel).toBeTruthy();
      });
    });

    test.each(schemas)('[$screenId] button grid buttons have accessibilityLabel', (schema) => {
      const grids = schema.contentBlocks.filter(b => b.blockType === 'BUTTON_GRID');
      grids.forEach((grid: ContentBlock) => {
        if (grid.blockType === 'BUTTON_GRID') {
          grid.buttons.forEach((btn, idx) => {
            expect(btn.accessibilityLabel).toBeTruthy();
            expect(btn.accessibilityHint).toBeTruthy();
          });
        }
      });
    });
  });

  describe('Voice Schema', () => {
    test.each(schemas)('[$screenId] has voice fallback', (schema) => {
      expect(schema.voice.fallback).toBeDefined();
      expect(schema.voice.fallback.message).toBeTruthy();
    });

    test.each(schemas)('[$screenId] fallback message ≤ 15 words', (schema) => {
      const wordCount = schema.voice.fallback.message.split(' ').length;
      expect(wordCount).toBeLessThanOrEqual(15);
    });

    test.each(schemas)('[$screenId] all commands have at least 1 utterance', (schema) => {
      schema.voice.commands.forEach(cmd => {
        expect(cmd.utterances.length).toBeGreaterThan(0);
      });
    });
  });

  describe('Data Sources', () => {
    test.each(schemas)('[$screenId] all data sources have offlineCacheTTL', (schema) => {
      schema.dataSources.forEach(ds => {
        expect(ds.offlineCacheTTL).toBeGreaterThan(0);
      });
    });
  });

  describe('Microcopy Tone', () => {
    const BANNED_WORDS = [
      'warning', 'error', 'failed', 'stupid', 'wrong',
      'critical', 'danger', 'detected', 'alert:', 'never',
    ];

    const extractAllText = (schema: ScreenSchema): string[] => {
      const texts: string[] = [];
      texts.push(schema.title);
      schema.voice.fallback?.message && texts.push(schema.voice.fallback.message);
      schema.voice.entrySpeak?.template && texts.push(schema.voice.entrySpeak.template);
      schema.emptyState?.title && texts.push(schema.emptyState.title);
      schema.emptyState?.body  && texts.push(schema.emptyState.body);
      schema.bottomActions.forEach(a => texts.push(a.label));
      return texts;
    };

    test.each(schemas)('[$screenId] no banned words in copy', (schema) => {
      const allText = extractAllText(schema).join(' ').toLowerCase();
      BANNED_WORDS.forEach(word => {
        // Allow "never" only in scam copy (shield screens)
        if (word === 'never' && schema.screenId.includes('SHIELD')) return;
        expect(allText).not.toContain(word);
      });
    });
  });

  describe('Emergency Access', () => {
    const NON_HELP_SCREENS = schemas.filter(
      s => s.screenId !== 'ELDER_HELP' &&
           s.screenId !== 'ELDER_SHIELD_BLACK' &&
           !s.screenId.includes('ONBOARDING')
    );

    test.each(NON_HELP_SCREENS)(
      '[$screenId] has EMERGENCY_BUTTON persistent element',
      (schema) => {
        expect(schema.persistent).toContain('EMERGENCY_BUTTON');
      }
    );
  });
});
