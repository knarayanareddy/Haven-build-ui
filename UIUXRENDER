import { useCallback } from 'react';
import { useNavigation } from '@react-navigation/native';
import * as Linking from 'expo-linking';
import type { ButtonAction, SystemAction, ScreenId } from '../schema/types';
import { useConfirmSheet } from './useConfirmSheet';
import { useMedicationStore } from '../stores/medicationStore';
import { useMessagesStore }   from '../stores/messagesStore';
import { useShieldStore }     from '../stores/shieldStore';
import { usePhoneCall }       from './usePhoneCall';

export function useActionHandler(currentScreenId: ScreenId) {
  const navigation     = useNavigation();
  const { showConfirm } = useConfirmSheet();
  const { confirmMedTaken, snoozeMed } = useMedicationStore();
  const { sendThinkingOfYou }          = useMessagesStore();
  const { trustContact, dismissAlert } = useShieldStore();
  const { callContact }                = usePhoneCall();

  const handle = useCallback((action: ButtonAction | SystemAction | unknown) => {
    const a = action as ButtonAction;
    if (!a?.type) return;

    switch (a.type) {

      case 'NAVIGATE':
        navigation.navigate(a.screenId as never);
        break;

      case 'SYSTEM':
        handleSystem(a.system as SystemAction);
        break;

      case 'SHEET':
        navigation.navigate(a.sheetId as never);
        break;

      case 'CALL':
        callContact(a.contactBinding);
        break;

      case 'VOICE_INTENT':
        // Handled by voice engine — no-op here
        break;

      case 'CONFIRM_THEN':
        showConfirm({
          ...a.confirm,
          onConfirm: () => handle(a.thenAction),
        });
        break;
    }
  }, [navigation, callContact, showConfirm]);

  const handleSystem = useCallback((system: SystemAction) => {
    switch (system) {
      case 'CONFIRM_TAKEN':         confirmMedTaken();                     break;
      case 'SNOOZE_REMINDER':       snoozeMed(15);                         break;
      case 'SEND_THINKING_OF_YOU':  sendThinkingOfYou();                   break;
      case 'TRUST_CONTACT':         trustContact();                        break;
      case 'CALL_FAMILY_TOGETHER':  callContact('primaryContact');         break;
      case 'CALL_EMERGENCY_SERVICES': callContact('emergencyServices');    break;
      case 'START_VOICE_INPUT':     /* Voice engine handles */             break;
      case 'OPEN_CAMERA_OCR':       navigation.navigate('CameraOCR' as never); break;
      case 'SCAN_DOCUMENT':         navigation.navigate('DocumentScanner' as never); break;
      case 'SPEAK_DAILY_BRIEF':     /* Voice engine handles */             break;
    }
  }, [confirmMedTaken, snoozeMed, sendThinkingOfYou, trustContact, callContact]);

  return { handle };
}

// ─────────────────────────────────────────────────────────────────────────────
// hooks/useTemplateString.ts
// Fills "{{variable}}" templates with live data
// ─────────────────────────────────────────────────────────────────────────────

export function useTemplateString(data: Record<string, unknown>) {
  const fill = (template: string): string => {
    if (!template) return '';
    return template.replace(/\{\{(\w+)\}\}/g, (_, key) => {
      const value = data[key];
      if (value === undefined || value === null) return '';
      return String(value);
    });
  };

  return { fill };
}

// ─────────────────────────────────────────────────────────────────────────────
// hooks/useIntentClassifier.ts
// Fast intent matching: utterances → VoiceIntent
// ─────────────────────────────────────────────────────────────────────────────

import type { VoiceCommand, VoiceIntent } from '../schema/types';

export function useIntentClassifier(commands: VoiceCommand[]) {
  const classify = (transcript: string): { intent: VoiceIntent; slots: Record<string, string> } | null => {
    const lower = transcript.toLowerCase().trim();

    for (const command of commands) {
      for (const utterance of command.utterances) {

        // Exact match
        if (utterance === lower) {
          return { intent: command.intent, slots: {} };
        }

        // Wildcard match (e.g. "remind me to *")
        if (utterance.endsWith('*')) {
          const prefix = utterance.slice(0, -1).trim();
          if (lower.startsWith(prefix)) {
            const slotValue = lower.slice(prefix.length).trim();
            const slotName  = command.slots?.[0]?.name ?? 'value';
            return { intent: command.intent, slots: { [slotName]: slotValue } };
          }
        }

        // Contains match (for multi-word partial triggers)
        if (utterance.length > 6 && lower.includes(utterance)) {
          return { intent: command.intent, slots: {} };
        }
      }
    }

    // Wildcard command (*) — catch all
    const wildcard = commands.find(c => c.utterances.includes('*'));
    if (wildcard) {
      const slotName = wildcard.slots?.[0]?.name ?? 'value';
      return { intent: wildcard.intent, slots: { [slotName]: lower } };
    }

    return null;
  };

  return { classify };
}
