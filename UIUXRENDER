// hooks/useScreenData.ts
// ─────────────────────────────────────────────────────────────────────────────
// Data fetching for a screen's declared data sources.
// Uses React Query — each data source becomes one cached query.
// ─────────────────────────────────────────────────────────────────────────────

import { useQueries, UseQueryResult } from '@tanstack/react-query';
import NetInfo from '@react-native-community/netinfo';
import AsyncStorage from '@react-native-async-storage/async-storage';
import type { DataSourceDescriptor } from '../schema/types';
import { havenAPI } from '../api/havenAPI';

export function useScreenData(
  sources:     DataSourceDescriptor[],
  options?:    { routeParams?: Record<string, string> }
): {
  data:       Record<string, unknown>;
  isLoading:  boolean;
  isError:    boolean;
  isOffline:  boolean;
} {
  const queries = useQueries({
    queries: sources.map(source => ({
      queryKey:     [source.queryKey, options?.routeParams],
      queryFn:      () => havenAPI.query(source.queryKey, options?.routeParams),
      staleTime:    source.offlineCacheTTL,
      gcTime:       source.offlineCacheTTL * 2,
      refetchInterval: source.refetchInterval,
      retry:        1,
      // Serve stale cache when offline
      networkMode:  'offlineFirst' as const,
    })),
  });

  // Merge all query results into a flat data map
  const data: Record<string, unknown> = {};
  queries.forEach((result: UseQueryResult, idx) => {
    if (result.data !== undefined) {
      data[sources[idx].key] = result.data;
    }
  });

  const isLoading = queries.every(q => q.isLoading) && queries.some(q => !q.data);
  const isError   = queries.some(q => q.isError);
  const isOffline = queries.some(q => q.fetchStatus === 'paused');

  return { data, isLoading, isError, isOffline };
}

