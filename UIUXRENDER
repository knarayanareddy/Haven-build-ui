HAVEN — Full Screen Schema + React Native Renderer Architecture
Part 1 — TypeScript Schema Type Definitions
Every screen is described by a ScreenSchema. The renderer reads it and produces a bespoke, fully accessible, elder-safe screen. No ad-hoc screen components allowed — if a screen needs to exist, it needs a schema first.

TypeScript

// schema/types.ts
// ─────────────────────────────────────────────────────────────────────────────
// ROOT SCHEMA TYPES
// ─────────────────────────────────────────────────────────────────────────────

/**
 * Top-level screen descriptor.
 * Every elder-facing screen is exactly one ScreenSchema.
 */
export interface ScreenSchema {
  // ── Identity ───────────────────────────────────────────────────────────────
  screenId:           ScreenId;
  title:              string;
  accessibilityLabel: string;

  // ── Layout ─────────────────────────────────────────────────────────────────
  layout:             LayoutVariant;
  backgroundColor?:   ThemeColorKey;
  headerVariant?:     HeaderVariant;

  // ── Content ────────────────────────────────────────────────────────────────
  contentBlocks:      ContentBlock[];
  maxPrimaryItems:    number;           // hard limit — build test fails if exceeded

  // ── Bottom actions (max 2) ─────────────────────────────────────────────────
  bottomActions:      BottomAction[];   // max 2, enforced by schema validator

  // ── Persistent elements (always visible) ──────────────────────────────────
  persistent:         PersistentElement[];

  // ── Voice ──────────────────────────────────────────────────────────────────
  voice:              VoiceSchema;

  // ── Empty state ────────────────────────────────────────────────────────────
  emptyState?:        EmptyStateSchema;

  // ── States ─────────────────────────────────────────────────────────────────
  states?:            ScreenStateMap;

  // ── Navigation ─────────────────────────────────────────────────────────────
  navigation:         NavigationSchema;

  // ── Data ───────────────────────────────────────────────────────────────────
  dataSources:        DataSourceDescriptor[];

  // ── Analytics ──────────────────────────────────────────────────────────────
  trackingId:         string;
}

// ── Screen IDs (all elder screens) ──────────────────────────────────────────
export type ScreenId =
  | 'ELDER_HOME'
  | 'ELDER_TODAY'
  | 'ELDER_MY_PILLS'
  | 'ELDER_PILL_DETAIL'
  | 'ELDER_TAKE_PILL'
  | 'ELDER_FAMILY'
  | 'ELDER_VOICE_MESSAGE'
  | 'ELDER_READ_MESSAGE'
  | 'ELDER_LIFE_STORY'
  | 'ELDER_HELP'
  | 'ELDER_SHIELD_AMBER'
  | 'ELDER_SHIELD_RED'
  | 'ELDER_SHIELD_BLACK'
  | 'ELDER_COACHING_CARD'
  | 'ELDER_DOCUMENT_EXPLAINER'
  | 'ELDER_WELLNESS_CHECKIN'
  | 'ELDER_COGNITIVE_CHECKIN'
  | 'ELDER_MEMORY_LANE'
  | 'ELDER_STORY_ARCHIVE'
  | 'ELDER_SETTINGS'
  | 'ELDER_ONBOARDING_WELCOME'
  | 'ELDER_ONBOARDING_VOICE_TEST'
  | 'ELDER_ONBOARDING_COMPLETE';

// ── Layouts ──────────────────────────────────────────────────────────────────
export type LayoutVariant =
  | 'HOME_GRID'        // 2×2 hero buttons
  | 'ONE_CARD'         // single card, scrollable rows
  | 'FULL_OVERLAY'     // modal-style, dim background
  | 'STORY'            // serif, warm bg, recorder
  | 'VOICE_FOCUS'      // giant mic, minimal distractions
  | 'EMERGENCY'        // red, giant call button
  | 'ONBOARDING';      // single panel, step-by-step

export type HeaderVariant =
  | 'GREETING'         // "Good Morning, Margaret" + Halo
  | 'TITLE_BACK'       // "← Today" — depth 2 screens
  | 'TITLE_ONLY'       // no back (rare — overlays)
  | 'HIDDEN';          // emergency / overlays

export type ThemeColorKey =
  | 'bg.primary'
  | 'bg.secondary'
  | 'bg.story'         // warm ivory
  | 'bg.emergency'     // soft red
  | 'bg.overlay_amber'
  | 'bg.overlay_red'
  | 'bg.overlay_black'
  | 'bg.night';        // deep navy for night mode

// ── Persistent elements ──────────────────────────────────────────────────────
export type PersistentElement =
  | 'EMERGENCY_BUTTON'
  | 'VOICE_BUTTON'
  | 'HALO_STATUS'
  | 'BACK_BUTTON';

// ─────────────────────────────────────────────────────────────────────────────
// CONTENT BLOCKS
// ─────────────────────────────────────────────────────────────────────────────

export type ContentBlock =
  | GreetingBlock
  | HaloBlock
  | ButtonGridBlock
  | CardBlock
  | ListBlock
  | MedicationNextBlock
  | VoicePromptBlock
  | RecorderBlock
  | AlertExplanationBlock
  | CoachingCardBlock
  | DocumentSummaryBlock
  | WellnessSelectorBlock
  | CognitiveChallengeBlock
  | PhotoGridBlock
  | FamilyMemberListBlock
  | TextBlock
  | DividerBlock
  | SpacerBlock;

// ── Base block interface ──────────────────────────────────────────────────────
interface BaseBlock {
  blockId:          string;
  blockType:        string;
  visible?:         VisibilityCondition;  // conditionally show/hide
  animateIn?:       AnimationSpec;
}

// ── Greeting ─────────────────────────────────────────────────────────────────
export interface GreetingBlock extends BaseBlock {
  blockType:        'GREETING';
  textTemplate:     string;              // "Good {{timeOfDay}}, {{elderName}}"
  subtextTemplate?: string;              // "{{dayName}}, {{date}}"
  textVariant:      'hero' | 'title';
  align:            'left' | 'center';
}

// ── Halo status ring ─────────────────────────────────────────────────────────
export interface HaloBlock extends BaseBlock {
  blockType:        'HALO';
  size:             'sm' | 'md' | 'lg';
  dataBinding:      'shieldStatus';
  showLabel:        boolean;
  labelMap: {
    safe:   string;
    amber:  string;
    red:    string;
  };
}

// ── 2×2 hero button grid ─────────────────────────────────────────────────────
export interface ButtonGridBlock extends BaseBlock {
  blockType:        'BUTTON_GRID';
  columns:          2;                   // always 2 for home
  buttons:          HeroButton[];        // exactly 4
}

export interface HeroButton {
  buttonId:         string;
  label:            string;
  icon:             string;             // emoji or SF symbol name
  iconPosition:     'top';             // always top for hero
  action:           ButtonAction;
  badgeBinding?:    BadgeBinding;       // e.g. unread count
  variant:          'primary' | 'danger' | 'safe';
  accessibilityLabel: string;
  accessibilityHint:  string;
}

// ── Card (wraps rows) ─────────────────────────────────────────────────────────
export interface CardBlock extends BaseBlock {
  blockType:        'CARD';
  cardVariant:      'default' | 'elevated' | 'flat'
                  | 'alert_amber' | 'alert_red'
                  | 'safe' | 'story' | 'memorial';
  rows:             CardRow[];
  maxRows:          number;             // build test enforces this
  header?:          string;
  headerIcon?:      string;
}

export type CardRow =
  | MedReminderRow
  | AppointmentRow
  | MessageRow
  | TaskRow
  | FamilyMemberRow
  | PromptRow
  | InfoRow
  | ActionRow;

interface BaseRow {
  rowId:            string;
  rowType:          string;
  tapAction:        RowAction;
  accessibilityLabel: string;
  accessibilityHint:  string;
}

export interface MedReminderRow extends BaseRow {
  rowType:          'MED_REMINDER';
  dataBinding:      'nextMedication';
  showTime:         boolean;
  showDescription:  boolean;           // plain description, not drug name
  showStatus:       boolean;
  statusBinding:    'medicationStatus';
}

export interface AppointmentRow extends BaseRow {
  rowType:          'APPOINTMENT';
  dataBinding:      'nextAppointment';
  showTime:         boolean;
  showLocation:     boolean;
}

export interface MessageRow extends BaseRow {
  rowType:          'FAMILY_MESSAGE';
  dataBinding:      'unreadMessages';
  showSenderName:   boolean;
  showPreview:      boolean;           // max 40 chars
  showAvatar:       boolean;
}

export interface TaskRow extends BaseRow {
  rowType:          'TASK';
  dataBinding:      'task';
  showTime:         boolean;
  showAttribution:  boolean;
  showComplete:     boolean;
}

export interface FamilyMemberRow extends BaseRow {
  rowType:          'FAMILY_MEMBER';
  dataBinding:      'familyMember';
  showAvatar:       boolean;
  showPresence:     boolean;
  inlineActions:    InlineAction[];    // max 2: "Thinking of you" + "Send voice"
}

export interface PromptRow extends BaseRow {
  rowType:          'PROMPT';
  promptText:       string;
  promptIcon:       string;
  cta:              string;
}

export interface InfoRow extends BaseRow {
  rowType:          'INFO';
  label:            string;
  value?:           string;
  valueBinding?:    string;
  icon?:            string;
}

export interface ActionRow extends BaseRow {
  rowType:          'ACTION';
  label:            string;
  icon:             string;
  style:            'normal' | 'destructive' | 'safe';
}

// ── Scrollable list ───────────────────────────────────────────────────────────
export interface ListBlock extends BaseBlock {
  blockType:        'LIST';
  dataBinding:      string;
  rowType:          CardRow['rowType'];
  maxVisible?:      number;
  emptyMessage:     string;
  showSectionHeader?: boolean;
  sectionKey?:      string;
}

// ── Medication "next dose" focus block ────────────────────────────────────────
export interface MedicationNextBlock extends BaseBlock {
  blockType:        'MED_NEXT';
  dataBinding:      'currentReminder';
  showLargeTime:    boolean;
  showPillDescription: boolean;
  showPillVisual:   boolean;           // colour/shape indicator
  primaryAction:    MedAction;
  secondaryAction:  MedAction;
}

export type MedAction = {
  label:            string;
  action:           'CONFIRM_TAKEN' | 'SNOOZE_REMINDER' | 'VIEW_DETAIL';
  style:            'primary' | 'secondary';
  accessibilityLabel: string;
};

// ── Voice prompt ──────────────────────────────────────────────────────────────
export interface VoicePromptBlock extends BaseBlock {
  blockType:        'VOICE_PROMPT';
  promptText:       string;
  subtext?:         string;
  showMicButton:    boolean;
  micSize:          'md' | 'lg' | 'xl';
  autoDismissOnComplete: boolean;
}

// ── Story recorder ────────────────────────────────────────────────────────────
export interface RecorderBlock extends BaseBlock {
  blockType:        'RECORDER';
  promptBinding:    'currentStoryPrompt';
  showWaveform:     boolean;
  showDuration:     boolean;
  showSkip:         boolean;
  skipLabel:        string;
  doneLabel:        string;
  maxDurationSeconds: number;
}

// ── Shield alert explanation ──────────────────────────────────────────────────
export interface AlertExplanationBlock extends BaseBlock {
  blockType:        'ALERT_EXPLANATION';
  level:            'amber' | 'red' | 'black';
  explanationBinding: 'scamExplanation';
  redFlagsBinding:  'scamRedFlags';
  showRedFlags:     boolean;
  maxRedFlags:      3;                 // never more than 3 bullets
  tone:             'warm';           // always warm tone
}

// ── Coaching card (in-call silent UI) ────────────────────────────────────────
export interface CoachingCardBlock extends BaseBlock {
  blockType:        'COACHING_CARD';
  requestBinding:   'scamRequestType';
  responseBinding:  'safeResponse';
  redFlagsBinding:  'realOrgNeverList';
  pinPosition:      'top';
  maxHeightPercent: 40;              // never > 40% of screen
  silent:           true;           // no sound ever
}

// ── Document summary ─────────────────────────────────────────────────────────
export interface DocumentSummaryBlock extends BaseBlock {
  blockType:        'DOCUMENT_SUMMARY';
  summaryBinding:   'documentSummary';
  showPoints:       boolean;         // 3 plain bullet points
  showDoctorQuestions: boolean;
  showActions:      boolean;
}

// ── Wellness selector ────────────────────────────────────────────────────────
export interface WellnessSelectorBlock extends BaseBlock {
  blockType:        'WELLNESS_SELECTOR';
  options: WellnessOption[];
}

export interface WellnessOption {
  value:            'great' | 'okay' | 'not_great';
  emoji:            string;
  label:            string;
  color:            string;
  accessibilityLabel: string;
}

// ── Cognitive challenge ───────────────────────────────────────────────────────
export interface CognitiveChallengeBlock extends BaseBlock {
  blockType:        'COGNITIVE_CHALLENGE';
  questionBinding:  'cognitiveQuestion';
  responseOptions:  'VOICE' | 'BUTTONS' | 'BOTH';
  tone:             'conversational';
  showSkip:         boolean;
  skipLabel:        string;
}

// ── Photo grid (memory lane) ─────────────────────────────────────────────────
export interface PhotoGridBlock extends BaseBlock {
  blockType:        'PHOTO_GRID';
  dataBinding:      'memoryPhotos';
  columns:          1 | 2;           // 2 max for elder — large tiles
  showCaption:      boolean;
  showDate:         boolean;
  tapAction:        'EXPAND_PHOTO';
}

// ── Family member list ────────────────────────────────────────────────────────
export interface FamilyMemberListBlock extends BaseBlock {
  blockType:        'FAMILY_LIST';
  dataBinding:      'familyMembers';
  showActions:      boolean;
  inlineActions:    InlineAction[];
}

// ── Text block ───────────────────────────────────────────────────────────────
export interface TextBlock extends BaseBlock {
  blockType:        'TEXT';
  text:             string;
  textBinding?:     string;
  variant:          'hero' | 'title' | 'heading' | 'body' | 'bodyLarge' | 'caption';
  align:            'left' | 'center' | 'right';
  color?:           string;
}

// ── Divider ───────────────────────────────────────────────────────────────────
export interface DividerBlock extends BaseBlock {
  blockType:        'DIVIDER';
  style:            'line' | 'space';
  spacing:          number;
}

// ── Spacer ────────────────────────────────────────────────────────────────────
export interface SpacerBlock extends BaseBlock {
  blockType:        'SPACER';
  size:             number;
}

// ─────────────────────────────────────────────────────────────────────────────
// ACTIONS
// ─────────────────────────────────────────────────────────────────────────────

export type ButtonAction =
  | { type: 'NAVIGATE'; screenId: ScreenId }
  | { type: 'VOICE_INTENT'; intent: VoiceIntent }
  | { type: 'SYSTEM'; system: SystemAction }
  | { type: 'SHEET'; sheetId: SheetId }
  | { type: 'CALL'; contactBinding: string }
  | { type: 'CONFIRM_THEN'; confirm: ConfirmSpec; thenAction: ButtonAction };

export type RowAction = ButtonAction;

export type InlineAction = {
  label:            string;
  icon:             string;
  action:           ButtonAction;
  style:            'primary' | 'secondary' | 'ghost';
  accessibilityLabel: string;
};

export type SystemAction =
  | 'SPEAK_DAILY_BRIEF'
  | 'START_VOICE_INPUT'
  | 'OPEN_CAMERA_OCR'
  | 'CONFIRM_TAKEN'
  | 'SNOOZE_REMINDER'
  | 'SEND_THINKING_OF_YOU'
  | 'START_STORY_RECORDING'
  | 'STOP_STORY_RECORDING'
  | 'SUBMIT_WELLNESS'
  | 'CALL_PRIMARY_CONTACT'
  | 'CALL_EMERGENCY_SERVICES'
  | 'DISMISS_ALERT'
  | 'TRUST_CONTACT'
  | 'PAUSE_TRANSACTION'
  | 'CALL_FAMILY_TOGETHER'
  | 'SCAN_DOCUMENT'
  | 'SUBMIT_COGNITIVE_RESPONSE'
  | 'OPEN_NFC_PROFILE';

export type SheetId =
  | 'SHEET_MEDICATION_DETAIL'
  | 'SHEET_TASK_DETAIL'
  | 'SHEET_MESSAGE_DETAIL'
  | 'SHEET_SCAM_DETAIL'
  | 'SHEET_CONFIRM_DISMISS'
  | 'SHEET_REFILL_REMINDER'
  | 'SHEET_TRANSPORT_BOOKING'
  | 'SHEET_LEGACY_CONFIRM';

export interface ConfirmSpec {
  title:            string;
  body:             string;
  confirmLabel:     string;
  cancelLabel:      string;
}

// ─────────────────────────────────────────────────────────────────────────────
// BOTTOM ACTIONS
// ─────────────────────────────────────────────────────────────────────────────

export interface BottomAction {
  actionId:         string;
  label:            string;
  icon?:            string;
  style:            'primary' | 'secondary' | 'ghost';
  action:           ButtonAction;
  fullWidth?:       boolean;
  accessibilityLabel: string;
  accessibilityHint: string;
}

// ─────────────────────────────────────────────────────────────────────────────
// VOICE SCHEMA
// ─────────────────────────────────────────────────────────────────────────────

export interface VoiceSchema {
  entrySpeak?:      SpeakSpec;          // what HAVEN says on screen load
  alwaysListening:  boolean;            // default false; opt-in only
  wakeWord?:        string;
  commands:         VoiceCommand[];
  fallback:         VoiceFallback;
}

export interface SpeakSpec {
  template:         string;            // "Good {{timeOfDay}}, {{elderName}}"
  bindings:         string[];
  voice:            'warm' | 'calm' | 'urgent_calm'; // urgent_calm = alert but not alarming
  delay_ms:         number;            // delay before auto-speaking
  skipIfSilentMode: boolean;
}

export interface VoiceCommand {
  commandId:        string;
  utterances:       string[];          // ["i took it", "done", "taken", "yes"]
  intent:           VoiceIntent;
  slots?:           VoiceSlot[];
  confirmBefore?:   boolean;
  confirmMessage?:  string;
}

export type VoiceIntent =
  | 'CONFIRM_MEDICATION_TAKEN'
  | 'SNOOZE_MEDICATION'
  | 'READ_DAILY_BRIEF'
  | 'CREATE_TASK'
  | 'SEND_THINKING_OF_YOU'
  | 'SEND_VOICE_MESSAGE'
  | 'READ_MESSAGES'
  | 'START_STORY'
  | 'SKIP_STORY'
  | 'SUBMIT_WELLNESS_GREAT'
  | 'SUBMIT_WELLNESS_OKAY'
  | 'SUBMIT_WELLNESS_NOT_GREAT'
  | 'CALL_FAMILY'
  | 'CALL_EMERGENCY'
  | 'DISMISS_ALERT_WITH_TRUST'
  | 'ACCEPT_SCAM_WARNING'
  | 'ANSWER_COGNITIVE'
  | 'READ_DOCUMENT'
  | 'NAVIGATE_HOME'
  | 'NAVIGATE_PILLS'
  | 'NAVIGATE_TODAY'
  | 'NAVIGATE_FAMILY';

export interface VoiceSlot {
  name:             string;
  type:             'TEXT' | 'DATE' | 'TIME' | 'PERSON' | 'AMOUNT';
  required:         boolean;
  reprompt:         string;
}

export interface VoiceFallback {
  message:          string;           // shown when HAVEN doesn't understand
  offerOptions:     boolean;          // show 2 big buttons as fallback
  options?:         VoiceFallbackOption[];
}

export interface VoiceFallbackOption {
  label:            string;
  intent:           VoiceIntent;
}

// ─────────────────────────────────────────────────────────────────────────────
// EMPTY STATES
// ─────────────────────────────────────────────────────────────────────────────

export interface EmptyStateSchema {
  icon:             string;
  title:            string;
  body:             string;
  action?:          EmptyStateAction;
  voicePrompt?:     string;
}

export interface EmptyStateAction {
  label:            string;
  action:           ButtonAction;
}

// ─────────────────────────────────────────────────────────────────────────────
// SCREEN STATES
// ─────────────────────────────────────────────────────────────────────────────

export type ScreenStateMap = Partial<Record<ScreenStateName, ScreenStateOverride>>;

export type ScreenStateName =
  | 'LOADING'
  | 'ERROR'
  | 'OFFLINE'
  | 'EMPTY'
  | 'AMBER_ALERT'
  | 'RED_ALERT'
  | 'MEDICATION_OVERDUE'
  | 'BEREAVEMENT';

export interface ScreenStateOverride {
  backgroundColor?:   ThemeColorKey;
  headerVariant?:     HeaderVariant;
  extraBlocks?:       ContentBlock[];
  replaceBlocks?:     ContentBlock[];
  bottomActions?:     BottomAction[];
  voiceOverride?:     Partial<VoiceSchema>;
}

// ─────────────────────────────────────────────────────────────────────────────
// NAVIGATION SCHEMA
// ─────────────────────────────────────────────────────────────────────────────

export interface NavigationSchema {
  fromScreens:      ScreenId[];        // which screens can navigate here
  backTarget?:      ScreenId;          // where Back goes
  depthFromHome:    0 | 1 | 2;        // enforced: never > 2
  isModal?:         boolean;
  isOverlay?:       boolean;
}

// ─────────────────────────────────────────────────────────────────────────────
// DATA SOURCES
// ─────────────────────────────────────────────────────────────────────────────

export interface DataSourceDescriptor {
  key:              string;
  queryKey:         string;
  refetchInterval?: number;            // ms — for real-time screens
  offlineCacheTTL:  number;            // ms — how long to serve stale data
  shape:            string;            // TypeScript type name for docs
}

// ─────────────────────────────────────────────────────────────────────────────
// VISIBILITY CONDITIONS
// ─────────────────────────────────────────────────────────────────────────────

export type VisibilityCondition =
  | { condition: 'DATA_EXISTS'; dataKey: string }
  | { condition: 'DATA_EMPTY'; dataKey: string }
  | { condition: 'FEATURE_FLAG'; flag: string }
  | { condition: 'USER_SETTING'; setting: string; value: unknown }
  | { condition: 'ALERT_LEVEL'; level: 'amber' | 'red' | 'black' }
  | { condition: 'TIME_OF_DAY'; from: string; to: string }
  | { condition: 'BEREAVEMENT_ACTIVE' }
  | { condition: 'AND'; conditions: VisibilityCondition[] }
  | { condition: 'OR';  conditions: VisibilityCondition[] };

// ─────────────────────────────────────────────────────────────────────────────
// ANIMATIONS
// ─────────────────────────────────────────────────────────────────────────────

export interface AnimationSpec {
  type:       'SLIDE_UP' | 'FADE_IN' | 'SCALE_IN' | 'BREATHING_PULSE' | 'NONE';
  duration:   number;                  // ms
  delay?:     number;                  // ms
  easing:     'smooth' | 'enter' | 'slow_ease';
}

// ─────────────────────────────────────────────────────────────────────────────
// BADGE BINDING
// ─────────────────────────────────────────────────────────────────────────────

export interface BadgeBinding {
  dataKey:    string;
  threshold:  number;                  // show badge only when count > threshold
  color:      'amber' | 'red' | 'blue';
  maxDisplay: number;                  // e.g. 9 → shows "9+" above
}
