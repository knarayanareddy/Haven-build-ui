// ─────────────────────────────────────────────────────────────────────────────
// ROW CONTENT RESOLVER
// Maps row data bindings to display values
// ─────────────────────────────────────────────────────────────────────────────

function resolveRowContent(
  row:  CardRow,
  data: Record<string, unknown>,
  fill: (s: string) => string
): {
  leftContent: { primary?: string; secondary?: string };
  rightContent?: string;
  icon?: string;
  badge?: { label: string; color: string };
} {
  switch (row.rowType) {

    case 'MED_REMINDER': {
      const med = data[row.dataBinding] as {
        plainDescription?: string;
        scheduledAt?: string;
        status?: string;
      } | null;
      if (!med) return { leftContent: {} };
      const time = med.scheduledAt
        ? new Date(med.scheduledAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
        : '';
      return {
        icon:         '💊',
        leftContent:  { primary: med.plainDescription ?? '', secondary: time },
        badge:        med.status === 'taken'
                        ? { label: 'Done ✓', color: 'green' }
                        : med.status === 'missed'
                          ? { label: 'Missed', color: 'amber' }
                          : undefined,
      };
    }

    case 'APPOINTMENT': {
      const appt = data[row.dataBinding] as {
        title?: string;
        dueAt?: string;
        location?: string;
      } | null;
      if (!appt) return { leftContent: {} };
      const time = appt.dueAt
        ? new Date(appt.dueAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
        : '';
      return {
        icon:         '🏥',
        leftContent:  { primary: appt.title ?? '', secondary: `${time}${appt.location ? ` · ${appt.location}` : ''}` },
      };
    }

    case 'FAMILY_MESSAGE': {
      const msg = data[row.dataBinding] as {
        senderName?: string;
        preview?: string;
      } | null;
      if (!msg) return { leftContent: {} };
      return {
        icon:         '💬',
        leftContent:  { primary: msg.senderName ?? '', secondary: msg.preview ?? '' },
        badge:        { label: 'New', color: 'blue' },
      };
    }

    case 'TASK': {
      const task = data[row.dataBinding] as {
        title?: string;
        dueAt?: string;
        familyAttribution?: string;
      } | null;
      if (!task) return { leftContent: {} };
      const time = task.dueAt
        ? new Date(task.dueAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })
        : '';
      return {
        icon:        '📌',
        leftContent: {
          primary:   task.title ?? '',
          secondary: [time, task.familyAttribution].filter(Boolean).join(' · '),
        },
      };
    }

    case 'PROMPT': {
      return {
        icon:         row.promptIcon,
        leftContent:  { primary: fill(row.promptText), secondary: row.cta },
      };
    }

    case 'INFO': {
      return {
        icon:         row.icon,
        leftContent:  {
          primary:    fill(row.label),
          secondary:  row.valueBinding ? String(data[row.valueBinding] ?? '') : row.value,
        },
      };
    }

    case 'ACTION': {
      return {
        icon:         row.icon,
        leftContent:  { primary: fill(row.label) },
      };
    }

    default:
      return { leftContent: {} };
  }
}

