{
  "expo": {
    "name": "HAVEN Carer",
    "slug": "haven-carer",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": { "backgroundColor": "#2C3E6B" },
    "ios": { 
      "supportsTablet": true, 
      "bundleIdentifier": "nl.haven.carer",
      "infoPlist": {
        "UISupportsDocumentBrowser": true
      }
    },
    "mac": {
      "bundleIdentifier": "nl.haven.app.mac",
      "minimumMacOSVersion": "12.0"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "android": { "adaptiveIcon": { "backgroundColor": "#2C3E6B" }, "package": "nl.haven.carer", "windowSoftInputMode": "adjustResize" },
    "plugins": ["expo-secure-store", "expo-local-authentication"]
  }
}
