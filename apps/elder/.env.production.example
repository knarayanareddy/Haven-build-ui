# ─────────────────────────────────────────────────────────────────────────────
# HAVEN Elder App — Production Environment Template
# Copy to .env.production and fill in values from your Supabase project dashboard
# DO NOT commit the filled-in .env.production file — it is gitignored
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL (Settings → API → Project URL)
EXPO_PUBLIC_SUPABASE_URL=https://<YOUR_PROJECT_REF>.supabase.co

# Supabase anon/public key (Settings → API → Project API Keys → anon/public)
EXPO_PUBLIC_SUPABASE_ANON_KEY=<YOUR_ANON_KEY>

# Environment identifier — must be "production" in prod
EXPO_PUBLIC_ENV=production

# Default locale for elderly interface
EXPO_PUBLIC_LOCALE=nl-NL

# Default timezone (IANA format)
EXPO_PUBLIC_TZ=Europe/Amsterdam

# Sentry DSN for error reporting (https://sentry.io/settings/<org>/projects/<project>/keys/)
EXPO_PUBLIC_SENTRY_DSN=
