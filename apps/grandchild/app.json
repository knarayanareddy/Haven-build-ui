{
  "expo": {
    "name": "HAVEN Hello",
    "slug": "haven-grandchild",
    "scheme": "havenhello",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": { "bundleIdentifier": "nl.haven.grandchild" },
    "android": {
      "package": "nl.haven.grandchild",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5B7FB8"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.INTERNET"
      ]
    },
    "plugins": [
      ["expo-audio", {
        "microphonePermission": "Allow HAVEN Hello to record your voice for Familiar Voice profiles."
      }],
      "expo-secure-store"
    ],
    "extra": {
      "eas": {
        "projectId": "b9cef469-3078-4162-81d5-5a53bb6abcbe"
      }
    }
  }
}
