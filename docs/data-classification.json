{
  "version": "1.2.2",
  "last_updated": "2026-06-11",
  "classes": {
    "1": {
      "name": "Class 1 — Openbaar",
      "definition": "Non-personal, non-sensitive. App UI text, community event data.",
      "controls": "Standard access control; public access allowed."
    },
    "2": {
      "name": "Class 2 — Persoonlijk",
      "definition": "Personal data (AVG Article 4). Name, phone, email, push tokens.",
      "controls": "Encrypted in transit (TLS 1.3), Row-Level Security (RLS) enforced, strict access control."
    },
    "3": {
      "name": "Class 3 — Gevoelig Persoonlijk",
      "definition": "Sensitive personal data. Location, financial, scam events.",
      "controls": "Class 2 controls + field-level encryption where feasible, strict access logging."
    },
    "4": {
      "name": "Class 4 — Bijzondere Categorie (AVG Art. 9)",
      "definition": "Health-adjacent data (medications, wellness, cognitive check-ins), precise location (transient, 24h), voice recordings (transient, 30d), crisis/distress signals, bereavement state.",
      "controls": "Class 3 controls + explicit consent + access audit logging + encryption at rest (AES-256) + strict retention bounds."
    },
    "5": {
      "name": "Class 5 — Verboden te verzamelen",
      "definition": "BSN (Burgerservicenummer). HAVEN does not collect, store, process, or transmit BSN under any circumstances.",
      "controls": "Hard prohibition enforced at schema, UI, Edge Function, and vendor contract level."
    }
  },
