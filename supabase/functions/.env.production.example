# ─────────────────────────────────────────────────────────────────────────────
# HAVEN Edge Functions — Production Environment Template
# Set these as Supabase secrets: supabase secrets set KEY=value
# DO NOT commit secrets — use the CLI to push them securely
# ─────────────────────────────────────────────────────────────────────────────

# Supabase project URL
SUPABASE_URL=https://<YOUR_PROJECT_REF>.supabase.co

# Supabase anon/public key — used for user-scoped Edge Function clients
SUPABASE_ANON_KEY=<YOUR_ANON_KEY>

# Service role key — grants full DB access, never expose to clients
# (Settings → API → Project API Keys → service_role)
SUPABASE_SERVICE_ROLE_KEY=<YOUR_SERVICE_ROLE_KEY>

# Environment
HAVEN_ENV=production
HAVEN_ALLOWED_ORIGINS=https://<YOUR_APP_DOMAIN>,haven://*

# Mock/live AI boundary
HAVEN_AI_MOCK=false
HAVEN_AI_MOCK_URL=

# OpenAI — used by fn-voice-pipeline, fn-companion-memory, fn-scam-pipeline
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4o-mini

# ElevenLabs TTS — used by fn-life-story-process, fn-notification-dispatch
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID_NL=
ELEVENLABS_VOICE_ID_EN=

# Expo push notifications — used by fn-notification-dispatch
EXPO_ACCESS_TOKEN=

# Sentry error tracking — used by Edge Functions
SENTRY_DSN=

# PSD2 / banking integration — used by fn-banking-ingress-buffer, fn-transaction-intercept
PSD2_WEBHOOK_SECRET=

# Tink PSD2 bank connection — used by fn-bank-connect
TINK_CLIENT_ID=
TINK_CLIENT_SECRET=
TINK_REDIRECT_URI=https://<YOUR_PROJECT_REF>.supabase.co/functions/v1/fn-bank-connect
TINK_TOKEN_ENCRYPTION_KEY=<BASE64_32_BYTE_AES_GCM_KEY>
HAVEN_API_URL=https://<YOUR_PROJECT_REF>.supabase.co
HAVEN_INTERNAL_FUNCTIONS_URL=https://<YOUR_PROJECT_REF>.supabase.co
HAVEN_BANK_CONNECT_REDIRECT=https://<YOUR_FAMILY_APP_DOMAIN>/dashboard?bank=connected

# MedMij FHIR integration — used by fn-medmij-fhir-import
MEDMIJ_CLIENT_ID=
MEDMIJ_CLIENT_SECRET=
MEDMIJ_IMPORT_SECRET=

# Regulatory escalation — used by critical care incident escalation
REGULATORY_ESCALATION_WEBHOOK_URL=
REGULATORY_ESCALATION_HMAC_SECRET=

# G-Standaard / Z-Index medication catalog — used by fn-medication-catalog-sync
GSTANDAARD_CLIENT_ID=

# Care system integration — used by fn-care-system-sync
CARE_SYSTEM_CLIENT_ID=
CARE_SYSTEM_CLIENT_SECRET=

# Log drain — used by fn-log-drain-config
LOG_DRAIN_TOKEN=

# Slack alerting — used by fn-observability-alert
SLACK_WEBHOOK_URL=

# Upstash Redis — used by fn-banking-stream-consumer, fn-banking-ingress-buffer
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=

# Internal request signing key — used by requireInternalAccess() in cron/background functions
# Generate with: openssl rand -hex 32
HAVEN_INTERNAL_KEY=

# WhatsApp fallback — used by fn-whatsapp-webhook and critical notification fallback
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_BUSINESS_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=

# Twilio / video provider — used by fn-video-call-create, fn-video-call-join-token
VIDEO_PROVIDER_API_KEY=
VIDEO_PROVIDER_API_SECRET=

# Email providers — used by weekly digest and refill notifications
RESEND_API_KEY=
SENDGRID_API_KEY=
HAVEN_FROM_EMAIL=noreply@haven.nl
